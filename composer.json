{
	"autoload":
	{
		"classmap":
			[
				"app/controllers/",
				"app/managers/",
				"app/models/",
				"app/services/"
			]
	},
	"require":
	{
		"vlucas/phpdotenv": "^5.6",
		"phpmailer/phpmailer": "^7.0",
		"railsware/mailtrap-php": "^3.11",
		"symfony/http-client": "^6.4",
		"nyholm/psr7": "^1.8"
	},
	"require-dev":
	{
		"symfony/var-dumper": "^6.0"
	},
	"config": {
		"allow-plugins": {
			"php-http/discovery": true
		}
	}
}
